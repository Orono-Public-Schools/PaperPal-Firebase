rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Authenticated users may read and write files under their own UID.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Everything else is locked down until per-path rules are defined.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
