rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Authenticated users may read and write files under their own UID.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Travel form attachments and receipts — owner can write, anyone authed can read
    match /travel-attachments/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }
    match /travel-receipts/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }
    match /check-receipts/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }

    // Everything else is locked down until per-path rules are defined.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
