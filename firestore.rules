rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Any authenticated user can check if their email is on the allowlist
    match /allowedExternalEmails/{email} {
      allow read: if request.auth != null;
    }

    // Submissions: authenticated users can create; can read/update their own
    match /submissions/{submissionId} {
      allow create: if request.auth != null
                    && request.resource.data.submitterUid == request.auth.uid;
      allow read: if request.auth != null
                  && resource.data.submitterUid == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.submitterUid == request.auth.uid
                    && resource.data.status == 'revisions_requested';
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
